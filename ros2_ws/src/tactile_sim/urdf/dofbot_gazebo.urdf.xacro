  </joint>

  <link name="camera_accel_optical_frame"/>

  <joint name="camera_accel_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="camera_accel_frame"/>
    <child link="camera_accel_optical_frame"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="wrist_rgb_camera" type="camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera</topic>
      <camera>
        <horizontal_fov>1.204</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.03</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
    <sensor name="wrist_depth_camera" type="depth_camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>camera_depth</topic>
      <camera>
        <horizontal_fov>1.204</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.03</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="arm_link4">
    <sensor name="wrist_imu" type="imu">
      <always_on>1</always_on>
      <update_rate>200</update_rate>
      <visualize>false</visualize>
      <topic>camera_imu</topic>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="arm_joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="grip_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rlink_joint2">
      <param name="mimic">grip_joint</param>
      <param name="multiplier">-1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rlink_joint3">
      <param name="mimic">grip_joint</param>
      <param name="multiplier">1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="llink_joint1">
      <param name="mimic">grip_joint</param>
      <param name="multiplier">-1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="llink_joint2">
      <param name="mimic">grip_joint</param>
      <param name="multiplier">1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="llink_joint3">
      <param name="mimic">grip_joint</param>
      <param name="multiplier">-1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin
      name="gz_ros2_control::GazeboSimROS2ControlPlugin"
      filename="libgz_ros2_control-system.so">
      <parameters>$(find tactile_sim)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
