<?xml version="1.0"?>
<robot name="phase6_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="pi" value="3.1415926535897931"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="base_gray">
        <color rgba="0.55 0.55 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="link1">
    <inertial><origin xyz="0 0 0.10" rpy="0 0 0"/><mass value="1.0"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.002"/></inertial>
    <visual><origin xyz="0 0 0.10" rpy="0 0 0"/><geometry><cylinder radius="0.03" length="0.20"/></geometry></visual>
    <collision><origin xyz="0 0 0.10" rpy="0 0 0"/><geometry><cylinder radius="0.03" length="0.20"/></geometry></collision>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${pi}" upper="${pi}" effort="20" velocity="2.0"/>
  </joint>

  <link name="link2">
    <inertial><origin xyz="0 0 0.10" rpy="0 0 0"/><mass value="0.9"/><inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.002"/></inertial>
    <visual><origin xyz="0 0 0.10" rpy="0 0 0"/><geometry><cylinder radius="0.028" length="0.20"/></geometry></visual>
    <collision><origin xyz="0 0 0.10" rpy="0 0 0"/><geometry><cylinder radius="0.028" length="0.20"/></geometry></collision>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="20" velocity="2.0"/>
  </joint>

  <link name="link3">
    <inertial><origin xyz="0 0 0.08" rpy="0 0 0"/><mass value="0.7"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><cylinder radius="0.024" length="0.16"/></geometry></visual>
    <collision><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><cylinder radius="0.024" length="0.16"/></geometry></collision>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="15" velocity="2.0"/>
  </joint>

  <link name="link4">
    <inertial><origin xyz="0 0 0.06" rpy="0 0 0"/><mass value="0.5"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 0.06" rpy="0 0 0"/><geometry><cylinder radius="0.021" length="0.12"/></geometry></visual>
    <collision><origin xyz="0 0 0.06" rpy="0 0 0"/><geometry><cylinder radius="0.021" length="0.12"/></geometry></collision>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${pi}" upper="${pi}" effort="10" velocity="2.5"/>
  </joint>

  <link name="link5">
    <inertial><origin xyz="0 0 0.05" rpy="0 0 0"/><mass value="0.4"/><inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0015" iyz="0" izz="0.0008"/></inertial>
    <visual><origin xyz="0 0 0.05" rpy="0 0 0"/><geometry><cylinder radius="0.018" length="0.10"/></geometry></visual>
    <collision><origin xyz="0 0 0.05" rpy="0 0 0"/><geometry><cylinder radius="0.018" length="0.10"/></geometry></collision>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="8" velocity="2.5"/>
  </joint>

  <link name="tool0">
    <inertial><origin xyz="0 0 0.04" rpy="0 0 0"/><mass value="0.25"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/></inertial>
    <visual><origin xyz="0 0 0.04" rpy="0 0 0"/><geometry><cylinder radius="0.015" length="0.08"/></geometry></visual>
    <collision><origin xyz="0 0 0.04" rpy="0 0 0"/><geometry><cylinder radius="0.015" length="0.08"/></geometry></collision>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${pi}" upper="${pi}" effort="6" velocity="3.0"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="joint1"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint2"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint3"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint4"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint5"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint6"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find tactile_sim)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
