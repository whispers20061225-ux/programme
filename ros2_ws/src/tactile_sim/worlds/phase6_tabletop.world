            <box>
              <size>1.0 0.8 0.04</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.45 0.35 1.0</ambient>
            <diffuse>0.65 0.55 0.45 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="target_cylinder">
