      <pose>0.432 0.05 0.444 0 0 0</pose>
      <link name="target_link">
        <inertial>
          <mass>0.16</mass>
          <inertia>
            <ixx>0.0003</ixx>
            <iyy>0.0003</iyy>
            <izz>0.0001</izz>
