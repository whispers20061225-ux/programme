<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <!-- Replace address with your Windows host-only adapter IPv4 -->
        <NetworkInterface address="192.168.147.1" />
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <Peers>
        <!-- Windows host-only adapter -->
        <Peer Address="192.168.147.1" />
        <!-- Replace address with your VM host-only IPv4 -->
        <Peer Address="192.168.147.128" />
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
